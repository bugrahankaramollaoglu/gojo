<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color1"
    tools:context=".HomeFragment">

    <ImageView
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentBottom="true"
        android:layout_margin="10dp"
        android:src="@drawable/bugra2" />

    <ImageView
        android:id="@+id/logo"
        android:layout_width="250dp"
        android:layout_height="250dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="25dp"
        android:src="@drawable/cropped_final" />

    <ImageView
        android:id="@+id/home_options"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="25dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:src="@drawable/mnue2" />


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/emailCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/passwordCard"
        android:layout_centerInParent="true"
        android:layout_marginBottom="15dp">

        <EditText
            android:id="@+id/emailText"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/input_rectangle"
            android:drawableStart="@drawable/email"
            android:drawablePadding="12dp"
            android:ems="10"
            android:hint="E-posta"
            android:inputType="textEmailAddress"
            android:padding="10dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textSize="14sp" />

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.card.MaterialCardView
        android:id="@+id/passwordCard"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:layout_marginBottom="10dp">

        <EditText
            android:id="@+id/passwordText"
            android:layout_width="300dp"
            android:layout_height="50dp"
            android:background="@drawable/input_rectangle"
            android:drawableStart="@drawable/lock"
            android:drawablePadding="15dp"
            android:ems="10"
            android:hint="Şifre"
            android:inputType="textPassword"
            android:padding="5dp"
            android:paddingStart="15dp"
            android:textColor="@color/black"
            android:textColorHint="@color/black"
            android:textSize="14sp" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/forgotPasswordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/passwordCard"
        android:layout_alignEnd="@id/passwordCard"
        android:layout_marginTop="5dp"
        android:clickable="true"
        android:text="Şifrenizi mi Unuttunuz?"
        android:textColor="@color/white" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/signupButton"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_below="@id/forgotPasswordText"
        android:layout_alignStart="@id/passwordCard"
        android:layout_marginTop="50dp"
        android:elevation="50dp"
        app:cardBackgroundColor="@color/white">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Kaydol"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="17sp" />

    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/signinButton"
        android:layout_width="140dp"
        android:layout_height="50dp"
        android:layout_below="@id/forgotPasswordText"
        android:layout_alignEnd="@id/passwordCard"
        android:layout_marginTop="50dp"
        android:elevation="50dp"
        app:cardBackgroundColor="@color/white">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="Giriş"
            android:textAlignment="center"
            android:textColor="@color/black"
            android:textSize="17sp" />

    </com.google.android.material.card.MaterialCardView>

    <TextView
        android:id="@+id/proverb"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/signinButton"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="150dp"
        android:text="@string/proverb"
        android:textColor="@color/white"
        android:textSize="17sp"
        android:textStyle="italic" />

    <TextView
        android:id="@+id/yazar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/proverb"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="5dp"
        android:text="A. Süheyl Ünver"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold" />


</RelativeLayout>